{
  "name": "fieldguide",
  "version": "0.2.0",
  "description": "Fieldguide — 知识图谱 + 问答 Agent 的本地项目学习工作台",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.vitest.json --noEmit",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "qa:baseline": "node scripts/qa-baseline.mjs",
    "qa:scenario": "node scripts/scenario-smoke.mjs",
    "bootstrap:ua": "node scripts/bootstrap-ua.mjs",
    "qa:graph": "node scripts/graph-e2e-smoke.mjs",
    "qa:his-go": "node scripts/his-go-smoke.mjs",
    "clean:dist": "node scripts/clean-dist.mjs",
    "pack": "node scripts/prepare-pack.mjs && electron-vite build && electron-builder --win --config",
    "dist": "node scripts/prepare-pack.mjs && electron-vite build && electron-builder --win --publish never"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@radix-ui/react-context-menu": "^2.3.3",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@understand-anything/core": "workspace:*",
    "better-sqlite3": "^11.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^25.10.10",
    "lucide-react": "^1.23.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^6.1.200",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.6.6",
    "react-pdf": "^10.4.1",
    "simple-git": "^3.36.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.4.1",
    "app-builder-lib": "25.0.0",
    "autoprefixer": "^10.5.2",
    "dmg-builder": "25.0.0",
    "electron": "^33.4.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^2.1.0"
  },
  "ua": {
    "repo": "https://github.com/Egonex-AI/Understand-Anything",
    "commit": "54754a6f97051d1d76c8758353d8ea41afe502a6"
  },
  "build": {
    "appId": "com.fieldguide.app",
    "productName": "Fieldguide",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/tree-sitter*/**",
      "**/node_modules/@tree-sitter-grammars/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "license": "NOTICE.md",
      "shortcutName": "Fieldguide"
    },
    "extraResources": [
      {
        "from": "resources/dashboard",
        "to": "dashboard",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/sample-project",
        "to": "sample-project",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
